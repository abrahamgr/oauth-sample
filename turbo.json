{
  "$schema": "https://turborepo.dev/schema.json",
  "globalDependencies": ["biome.json", "tsconfig.json"],
  "globalEnv": ["NODE_ENV"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        "build/**",
        "dist/**",
        ".react-router/types/**",
        "tsconfig.tsbuildinfo"
      ],
      "inputs": ["$TURBO_DEFAULT$", ".env", ".env.*"],
      "env": [
        "PORT",
        "API_URL",
        "APP_URL",
        "IDP_URL",
        "DATABASE_URL",
        "JWT_SECRET",
        "SESSION_SECRET",
        "INTERNAL_SECRET",
        "SMTP_HOST",
        "SMTP_PORT",
        "SMTP_FROM",
        "VITE_*"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "env": [
        "PORT",
        "API_URL",
        "APP_URL",
        "IDP_URL",
        "DATABASE_URL",
        "JWT_SECRET",
        "SESSION_SECRET",
        "INTERNAL_SECRET",
        "SMTP_HOST",
        "SMTP_PORT",
        "SMTP_FROM",
        "VITE_*"
      ]
    },
    "start": {
      "env": [
        "PORT",
        "API_URL",
        "APP_URL",
        "IDP_URL",
        "DATABASE_URL",
        "JWT_SECRET",
        "SESSION_SECRET",
        "INTERNAL_SECRET",
        "SMTP_HOST",
        "SMTP_PORT",
        "SMTP_FROM",
        "VITE_*"
      ]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env", ".env.*"],
      "outputs": [".react-router/types/**"]
    },
    "//#biome-lint": {
      "inputs": [
        "biome.json",
        "apps/**/*.{ts,tsx,js,jsx,json}",
        "packages/**/*.{ts,tsx,js,jsx,json}",
        "!**/dist/**",
        "!**/build/**",
        "!**/.react-router/**",
        "!**/node_modules/**"
      ]
    },
    "db:push": {
      "cache": false,
      "persistent": false,
      "env": ["DATABASE_URL"]
    },
    "db:generate": {
      "cache": false,
      "env": ["DATABASE_URL"]
    },
    "db:migrate": {
      "cache": false,
      "persistent": false,
      "env": ["DATABASE_URL"]
    }
  }
}
