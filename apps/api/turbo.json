{
  "extends": ["//"],
  "tasks": {
    "build": {
      "env": [
        "NODE_ENV",
        "PORT",
        "DATABASE_URL",
        "JWT_SECRET",
        "SESSION_SECRET",
        "INTERNAL_SECRET",
        "IDP_URL",
        "APP_URL",
        "SMTP_HOST",
        "SMTP_PORT",
        "SMTP_FROM"
      ]
    },
    "dev": {
      "env": [
        "NODE_ENV",
        "PORT",
        "DATABASE_URL",
        "JWT_SECRET",
        "SESSION_SECRET",
        "INTERNAL_SECRET",
        "IDP_URL",
        "APP_URL",
        "SMTP_HOST",
        "SMTP_PORT",
        "SMTP_FROM"
      ]
    },
    "start": {
      "env": [
        "NODE_ENV",
        "PORT",
        "DATABASE_URL",
        "JWT_SECRET",
        "SESSION_SECRET",
        "INTERNAL_SECRET",
        "IDP_URL",
        "APP_URL",
        "SMTP_HOST",
        "SMTP_PORT",
        "SMTP_FROM"
      ]
    },
    "typecheck": {
      "env": ["NODE_ENV"]
    },
    "db:push": { "env": ["DATABASE_URL"] },
    "db:generate": { "env": ["DATABASE_URL"] },
    "db:migrate": { "env": ["DATABASE_URL"] }
  }
}
