{
  "name": "oauth-sample",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run //#biome-lint",
    "biome-lint": "biome check .",
    "typecheck": "turbo run typecheck",
    "check": "biome check --write .",
