{
  "$schema": "https://raw.githubusercontent.com/firebase/firebase-tools/refs/heads/main/schema/firebase-config.json",
  "apphosting": [
    {
      "backendId": "api",
      "rootDir": "packages/api",
      "alwaysDeployFromSource": true,
      "ignore": []
    },
    {
      "backendId": "idp",
      "rootDir": "packages/idp",
      "alwaysDeployFromSource": true,
      "ignore": []
    }
  ],
  "hosting": {
    "public": "packages/app/dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "/api/**",
        "run": {
          "serviceId": "api",
          "region": "us-east4"
        }
      },
      {
        "source": "/idp/**",
        "run": {
          "serviceId": "idp",
          "region": "us-east4"
        }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
