{
  "$schema": "https://raw.githubusercontent.com/firebase/firebase-tools/refs/heads/main/schema/firebase-config.json",
  "apphosting": [
    {
      "backendId": "api",
      "rootDir": "apps/api",
      "alwaysDeployFromSource": true,
      "ignore": []
    },
    {
      "backendId": "idp",
      "rootDir": "apps/idp",
      "alwaysDeployFromSource": true,
      "ignore": []
    }
  ],
  "hosting": {
    "public": "apps/app/dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "/api/**",
        "run": {
          "serviceId": "api",
          "region": "us-east4"
        }
      },
      {
        "source": "/idp/**",
        "run": {
          "serviceId": "idp",
          "region": "us-east4"
        }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "storage": {
    "rules": "storage.rules"
  },
  "emulators": {
    "storage": {
      "port": 9199
    },
    "hosting": {
      "port": 5003
    },
    "ui": {
      "enabled": true,
      "port": 8080
    },
    "singleProjectMode": true
  }
}
